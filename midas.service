[Unit]
Description=Midas — Autonomous BTC Trading Agent
After=network.target

[Service]
Type=simple
User=kyle
WorkingDirectory=/home/kyle/TradingAgent
EnvironmentFile=/home/kyle/TradingAgent/.env
ExecStart=/home/kyle/TradingAgent/venv/bin/python main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
